    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/yargs": "^17.0.35",
    "bestzip": "^2.2.2",
    "chalk": "^5.6.2",
    "liquidjs": "^10.25.0",
    "sharp": "^0.34.5",
    "svelte": "^5.53.10",
    "unocss": "^66.6.6",
    "vite": "^7.3.1",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0"
