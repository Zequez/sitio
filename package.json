{
  "name": "@ezequielschw/sitio",
  "version": "0.1.2",
  "type": "module",
  "description": "Personal web system builder mostly for static sites. Powered by Bun, Vite, UnoCSS, LiquidJS, Svelte",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zequez/sitio.git"
  },
